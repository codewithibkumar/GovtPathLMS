# ---------------------------------------------------------------------------
# GovPath Academy — environment variables
# Copy to .env.local for local dev. In Coolify, add these as the app's env vars.
# ---------------------------------------------------------------------------

# --- Database ---------------------------------------------------------------
# Local: mongodb://127.0.0.1:27017/govpath
# Atlas: mongodb+srv://user:pass@cluster.mongodb.net/govpath?retryWrites=true&w=majority
MONGODB_URI="mongodb://127.0.0.1:27017/govpath"

# --- NextAuth ---------------------------------------------------------------
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
# Local: http://localhost:3000 | Prod: https://academy.yourdomain.com
NEXTAUTH_URL="http://localhost:3000"

# --- Google OAuth (optional) ------------------------------------------------
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Razorpay (Payments) ----------------------------------------------------
# https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="xxxxxxxxxxxxxxxxxxxxxxxx"
# Webhook secret set in Razorpay dashboard -> Settings -> Webhooks
RAZORPAY_WEBHOOK_SECRET="xxxxxxxxxxxx"
# Public key id exposed to the browser checkout widget (same as RAZORPAY_KEY_ID)
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxxx"

# --- Cloudflare R2 (S3-compatible video/thumbnail storage) ------------------
# R2 endpoint: https://<accountid>.r2.cloudflarestorage.com
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="govpath-media"
R2_ENDPOINT="https://<accountid>.r2.cloudflarestorage.com"
# Optional public base URL for thumbnails (R2 public bucket or custom domain)
R2_PUBLIC_BASE_URL="https://media.yourdomain.com"

# --- App --------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="GovPath Academy"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
